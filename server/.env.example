# Local development values. Mirror these keys in Vercel Project Settings -> Environment Variables.
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
PORT=3000

# Paste the full Google service account JSON as a single-line string when developing locally
# or set GOOGLE_APPLICATION_CREDENTIALS to the absolute path of the JSON file.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional: API-key fallback if Vertex config is not present.
# GEMINI_API_KEY=your-gemini-api-key

# Optional: override the default Vertex request timeout in milliseconds.
FLORISH_VERTEX_TIMEOUT_MS=3500
